{
	"$schema": "https://getcomposer.org/schema.json",
	"repositories": [
		{
			"type": "package",
			"package": {
				"name": "enlightn/security-checker",
				"version": "2.0.0",
				"source": {
					"type": "git",
					"url": "https://github.com/enlightn/security-checker.git",
					"reference": "v2.0.0"
				},
				"autoload": {
					"psr-4": {
						"Enlightn\\SecurityChecker\\": "src/"
					}
				},
				"bin": ["security-checker"],
				"require": {
					"php": ">=8.2",
					"ext-json": "*",
					"symfony/console": "^7|^8",
					"symfony/finder": "^3|^4|^5|^6|^7|^8",
					"symfony/process": "^3.4|^4|^5|^6|^7|^8",
					"symfony/yaml": "^3.4|^4|^5|^6|^7|^8",
					"guzzlehttp/guzzle": "^6.3|^7.0"
				}
			}
		}
	],
	"name": "laravel/vue-starter-kit",
	"type": "project",
	"description": "The skeleton application for the Laravel framework.",
	"keywords": ["laravel", "framework"],
	"license": "MIT",
	"require": {
		"php": "^8.2",
		"bacon/bacon-qr-code": "^3.1",
		"barryvdh/laravel-dompdf": "^3.1",
		"http-interop/http-factory-guzzle": "^1.2",
		"inertiajs/inertia-laravel": "^2.0",
		"intervention/image": "^3.0",
		"jenssegers/agent": "^2.6",
		"laravel/fortify": "^1.30",
		"laravel/framework": "^12.0",
		"laravel/horizon": "^5.47",
		"laravel/octane": "*",
		"laravel/pulse": "^1.7",
		"laravel/reverb": "^1.10",
		"laravel/sanctum": "^4.0",
		"laravel/scout": "^11.1",
		"laravel/socialite": "^5.27",
		"laravel/tinker": "^2.10.1",
		"laravel/wayfinder": "^0.1.9",
		"meilisearch/meilisearch-php": "^1.0",
		"mews/purifier": "^3.4",
		"minishlink/web-push": "^10.1",
		"mpdf/mpdf": "^8.1.1",
		"pbmedia/laravel-ffmpeg": "^8.9",
		"phpoffice/phpspreadsheet": "^5.7",
		"pragmarx/google2fa": "^9.0"
	},
	"require-dev": {
		"exin/enlightn": "^2.11",
		"fakerphp/faker": "^1.23",
		"larastan/larastan": "^3.10",
		"laravel/pail": "^1.2.2",
		"laravel/pint": "^1.24",
		"laravel/sail": "^1.41",
		"laravel/telescope": "^5.20",
		"mockery/mockery": "^1.6",
		"nunomaduro/collision": "^8.6",
		"pestphp/pest": "^4.4",
		"pestphp/pest-plugin-laravel": "^4.1"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/",
			"Database\\Factories\\": "database/factories/",
			"Database\\Seeders\\": "database/seeders/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"scripts": {
		"setup": [
			"composer install",
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
			"@php artisan key:generate",
			"@php artisan migrate --force",
			"npm install",
			"npm run build"
		],
		"dev": [
			"Composer\\Config::disableProcessTimeout",
			"npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
		],
		"dev:ssr": [
			"npm run build:ssr",
			"Composer\\Config::disableProcessTimeout",
			"npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
		],
		"lint": ["pint --parallel"],
		"lint:check": ["pint --parallel --test"],
		"ci:check": [
			"Composer\\Config::disableProcessTimeout",
			"npm run lint",
			"npm run types:check",
			"@test"
		],
		"test": [
			"@php artisan config:clear --ansi",
			"@lint:check",
			"@php artisan test"
		],
		"post-autoload-dump": [
			"Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
			"@php artisan package:discover --ansi"
		],
		"post-update-cmd": [
			"@php artisan vendor:publish --tag=laravel-assets --ansi --force"
		],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"post-create-project-cmd": [
			"@php artisan key:generate --ansi",
			"@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
			"@php artisan migrate --graceful --ansi"
		],
		"pre-package-uninstall": [
			"Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
		]
	},
	"extra": {
		"laravel": {
			"dont-discover": []
		}
	},
	"config": {
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true,
		"platform-check": false,
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		},
		"audit": {
			"ignore": {
				"GHSA-m557-wrgg-6rp4": "Reason: enlightn/security-checker v2.0.0 has a known advisory, but no patched v2 release is available and the package is a development tool (exin/enlightn dependency) not exposed to production traffic."
			}
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
