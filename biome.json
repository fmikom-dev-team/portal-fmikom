{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"recommended": true
			},
			"suspicious": {
				"recommended": true,
				"noExplicitAny": "off"
			},
			"correctness": {
				"useQwikValidLexicalScope": "off",
				"useHookAtTopLevel": "off",
				"noUnusedVariables": "off",
				"noUnusedImports": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["resources/js/components/ui/**"],
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": ["**/*.vue"],
			"linter": {
				"rules": {
					"suspicious": {
						"noRedeclare": "off",
						"noExplicitAny": "warn"
					}
				}
			}
		}
	]
}
