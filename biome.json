{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!!resources/css",
			"!!resources/js/components",
			"!!resources/js/layouts",
			"!!resources/js/lib",
			"!!resources/js/wayfinder",
			"!!resources/js/utils",
			"!!resources/js/pages/Modules/Fast",
			"!!resources/js/pages/Modules/Portal",
			"!!resources/js/pages/Modules/Trace",
			"!!resources/js/pages/Modules/Wims",
			"!!resources/js/pages/WorkOs",
			"!!resources/js/pages/auth",
			"!!resources/js/pages/settings",
			"!!resources/js/pages/Dashboard.vue",
			"!!resources/js/pages/Portal.vue",
			"!!resources/js/pages/Welcome.vue",
			"!!resources/js/app.ts",
			"!!resources/js/ssr.ts",
			"!!node_modules",
			"!!vendor",
			"!!storage",
			"!!bootstrap",
			"!!public"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"recommended": true,
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"recommended": true,
				"noExplicitAny": "off"
			},
			"correctness": {
				"useQwikValidLexicalScope": "off",
				"useHookAtTopLevel": "off",
				"noUnusedVariables": "off",
				"noUnusedImports": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["resources/js/components/ui/**"],
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": ["**/*.vue"],
			"linter": {
				"rules": {
					"suspicious": {
						"noRedeclare": "off",
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
