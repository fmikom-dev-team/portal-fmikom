{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "dev:full": "concurrently -n \"vite,laravel,queue\" -c \"blue,green,yellow\" \"npm run dev\" \"php artisan serve\" \"php artisan queue:listen\"",
        "dev:tunnel": "export CLOUDFLARE_TUNNEL_TOKEN=$(grep -o '^CLOUDFLARE_TUNNEL_TOKEN=.*' .env | cut -d= -f2-) && concurrently -n \"laravel,queue,reverb,tunnel\" -c \"green,yellow,blue,magenta\" \"php artisan octane:start --port=8000 --caddyfile=Caddyfile\" \"php artisan queue:listen\" \"php artisan reverb:start\" \"cloudflared tunnel run --token $CLOUDFLARE_TUNNEL_TOKEN\"",
        "format": "biome format . --write",
        "lint": "biome check .",
        "lint:fix": "biome check . --write",
        "types:check": "vue-tsc --noEmit"
    },
    "devDependencies": {
