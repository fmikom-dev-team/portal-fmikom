##############################################################################
# Portal FMIKOM — Playwright Testing Environment
# JANGAN commit file ini ke version control jika berisi password nyata.
# Salin file ini dan isi sesuai environment Anda.
##############################################################################

APP_NAME="Portal-Fmikom"
APP_ENV=testing
APP_KEY=base64:88PCQsfaANhjq0hfPEHRB1zWRYeTmOm31AIfkkIJQyQ=
APP_DEBUG=true
APP_URL=http://localhost:8001
ASSET_URL=/

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (test database terpisah) ──────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portal_fmikom_test
DB_USERNAME=root
DB_PASSWORD=

# ── Session (cookie-based, tidak perlu Redis) ──────────────────────────────
SESSION_DRIVER=cookie
SESSION_COOKIE=fm_sess_test
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ── Cache (array, no Redis needed) ────────────────────────────────────────
CACHE_STORE=array

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (log driver untuk testing) ───────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="test@portal-fmikom.test"
MAIL_FROM_NAME="Portal FMIKOM Test"

VITE_APP_NAME="${APP_NAME}"

# ── Google OAuth (disabled for testing) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── Reverb (disabled for testing) ─────────────────────────────────────────
REVERB_APP_ID=test
REVERB_APP_KEY=test
REVERB_APP_SECRET=test
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY=test
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# ── WorkOS (disabled for testing) ─────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_WEBHOOK_SECRET=

# ── Radar Shield (disabled for testing) ───────────────────────────────────
RADAR_ENABLED=false

# ── Telescope (disabled for testing) ─────────────────────────────────────
TELESCOPE_ENABLED=false

# ── FFmpeg ───────────────────────────────────────────────────────────────
FFMPEG_BINARIES=
FFPROBE_BINARIES=

# ── ClamAV (disabled for testing) ─────────────────────────────────────────
CLAMAV_ENABLED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ── Cloudflare Tunnel (tidak dipakai saat testing) ────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── Playwright Base URL (override jika perlu) ─────────────────────────────
PLAYWRIGHT_BASE_URL=http://localhost:8001
